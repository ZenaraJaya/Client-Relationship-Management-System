APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=Asia/Kuala_Lumpur

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Outbound email delivery mode: auto, mail, resend_api
EMAIL_DELIVERY_MODE=auto
RESEND_API_KEY=
RESEND_FROM_ADDRESS=
RESEND_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Frontend CORS Origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_ORIGIN_PATTERNS=/^https:\/\/.*\.vercel\.app$/

# Token TTL in minutes
AUTH_TOKEN_TTL_MINUTES=720

# Calendar Reminder Sync
CALENDAR_REMINDERS_ENABLED=false
CALENDAR_REMINDER_HOUR=9
CALENDAR_PRE_REMINDER_MINUTES=15
CALENDAR_DUE_REMINDER_GRACE_MINUTES=5
CALENDAR_EVENT_REMINDER_MINUTES=15
CALENDAR_EVENT_POPUP_REMINDER_ENABLED=true
CALENDAR_EVENT_EMAIL_REMINDER_ENABLED=false
CALENDAR_REMINDER_DURATION_MINUTES=30
CALENDAR_REMINDER_REQUEST_TIMEOUT=8
CALENDAR_REMINDER_CONNECT_TIMEOUT=4
CALENDAR_REMINDER_ATTENDEE_EMAIL=
CALENDAR_SYNC_AUTH_USER_ATTENDEE=false
CALENDAR_SYNC_AUTH_ADMIN_ONLY=false
CALENDAR_SYNC_OWNER_ATTENDEE=false
CALENDAR_SYNC_CLIENT_ATTENDEE=false
CALENDAR_EMAIL_NOTIFICATIONS_ENABLED=true
CALENDAR_REMINDER_NOTIFICATION_EMAIL=
CALENDAR_REMINDER_ADMIN_EMAILS=
CALENDAR_NOTIFY_CLIENT_EMAIL=true
CALENDAR_NOTIFY_OWNER_EMAIL=false
CALENDAR_NOTIFY_AUTH_USER_EMAIL=false
CALENDAR_NOTIFY_AUTH_ADMIN_ONLY=false
CALENDAR_NOTIFY_ATTENDEE_EMAIL=false
CALENDAR_NOTIFY_ADMIN_USERS=false
CALENDAR_NOTIFY_FROM_ADDRESS=false

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS=
GOOGLE_CALENDAR_ID=

# Microsoft Graph Calendar
MICROSOFT_CALENDAR_ENABLED=false
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALENDAR_USER_ID=

# Firestore -> Laravel delete sync webhook
FIRESTORE_SYNC_SECRET=
